{
  "name": "Track People",
  "description": "Detect people and assign stable tracker IDs across frames with ByteTrack. Run with a Stream source (RTSP, webcam, or video URL) to see IDs persist. The Tracker chip toggles the #ID badge on each box.",
  "specification": {
    "version": "1.0",
    "inputs": [
      { "type": "WorkflowImage", "name": "image" },
      { "type": "WorkflowParameter", "name": "min_confidence", "default_value": 0.3 }
    ],
    "steps": [
      {
        "type": "roboflow_core/roboflow_object_detection_model@v1",
        "name": "detector",
        "images": "$inputs.image",
        "model_id": "yolov8n-640",
        "confidence": "$inputs.min_confidence",
        "class_filter": ["person"]
      },
      {
        "type": "roboflow_core/byte_tracker@v3",
        "name": "tracker",
        "image": "$inputs.image",
        "detections": "$steps.detector.predictions"
      }
    ],
    "outputs": [
      { "type": "JsonField", "name": "image", "selector": "$inputs.image" },
      { "type": "JsonField", "name": "predictions", "selector": "$steps.tracker.tracked_detections" }
    ]
  }
}
