{
  "name": "Detect → Crop → Classify",
  "description": "Two-stage pipeline: object detection produces candidate boxes, each is cropped and passed to a classifier for fine-grained labelling.",
  "specification": {
    "version": "1.0",
    "inputs": [
      { "type": "WorkflowImage", "name": "image" }
    ],
    "steps": [
      {
        "type": "roboflow_core/roboflow_object_detection_model@v2",
        "name": "detector",
        "images": "$inputs.image",
        "model_id": "yolov8n-640",
        "confidence": 0.35
      },
      {
        "type": "roboflow_core/dynamic_crop@v1",
        "name": "crop",
        "image": "$inputs.image",
        "predictions": "$steps.detector.predictions"
      },
      {
        "type": "roboflow_core/roboflow_classification_model@v2",
        "name": "classifier",
        "images": "$steps.crop.crops",
        "model_id": "vehicle-classification-eapcd/2"
      }
    ],
    "outputs": [
      { "type": "JsonField", "name": "detections", "selector": "$steps.detector.predictions" },
      { "type": "JsonField", "name": "classifications", "selector": "$steps.classifier.predictions" }
    ]
  }
}
