{
  "name": "Detect + Visualize",
  "description": "Classic starter: run an object detection model on an image and draw bounding boxes over the input.",
  "specification": {
    "version": "1.0",
    "inputs": [
      { "type": "WorkflowImage", "name": "image" }
    ],
    "steps": [
      {
        "type": "roboflow_core/roboflow_object_detection_model@v2",
        "name": "model",
        "images": "$inputs.image",
        "model_id": "yolov8n-640",
        "confidence": 0.4
      },
      {
        "type": "roboflow_core/bounding_box_visualization@v1",
        "name": "bbox_viz",
        "image": "$inputs.image",
        "predictions": "$steps.model.predictions"
      }
    ],
    "outputs": [
      { "type": "JsonField", "name": "predictions", "selector": "$steps.model.predictions" },
      { "type": "JsonField", "name": "annotated_image", "selector": "$steps.bbox_viz.image" }
    ]
  }
}
