{
  "name": "SAM3 with Prompts",
  "description": "Prompt SAM 3 with freeform text (e.g. 'person' or 'car') to produce instance masks, then visualize with polygons.",
  "specification": {
    "version": "1.0",
    "inputs": [
      { "type": "WorkflowImage", "name": "image" },
      { "type": "WorkflowParameter", "name": "classes", "default_value": "person" }
    ],
    "steps": [
      {
        "type": "roboflow_core/sam3@v1",
        "name": "sam",
        "images": "$inputs.image",
        "class_names": "$inputs.classes",
        "threshold": 0.5
      },
      {
        "type": "roboflow_core/polygon_visualization@v1",
        "name": "mask_viz",
        "image": "$inputs.image",
        "predictions": "$steps.sam.predictions"
      }
    ],
    "outputs": [
      { "type": "JsonField", "name": "predictions", "selector": "$steps.sam.predictions" },
      { "type": "JsonField", "name": "mask_image", "selector": "$steps.mask_viz.image" }
    ]
  }
}
