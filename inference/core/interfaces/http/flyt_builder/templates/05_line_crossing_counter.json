{
  "name": "Line-Crossing Counter",
  "description": "Count people who cross a line. The line and live in/out counts are painted server-side; bboxes and tracker IDs are drawn client-side. Best paired with a Stream source — a still image always reads 0/0. Edit `line_segment` to position the line over your scene.",
  "specification": {
    "version": "1.0",
    "inputs": [
      { "type": "WorkflowImage", "name": "image" },
      { "type": "WorkflowParameter", "name": "min_confidence", "default_value": 0.3 }
    ],
    "steps": [
      {
        "type": "roboflow_core/roboflow_object_detection_model@v1",
        "name": "detector",
        "images": "$inputs.image",
        "model_id": "yolov8n-640",
        "confidence": "$inputs.min_confidence",
        "class_filter": ["person"]
      },
      {
        "type": "roboflow_core/byte_tracker@v3",
        "name": "tracker",
        "image": "$inputs.image",
        "detections": "$steps.detector.predictions"
      },
      {
        "type": "roboflow_core/line_counter@v2",
        "name": "line",
        "image": "$inputs.image",
        "detections": "$steps.tracker.tracked_detections",
        "line_segment": [[100, 240], [540, 240]]
      },
      {
        "type": "roboflow_core/line_counter_visualization@v1",
        "name": "line_paint",
        "image": "$inputs.image",
        "zone": [[100, 240], [540, 240]],
        "count_in": "$steps.line.count_in",
        "count_out": "$steps.line.count_out"
      }
    ],
    "outputs": [
      { "type": "JsonField", "name": "scene", "selector": "$steps.line_paint.image" },
      { "type": "JsonField", "name": "predictions", "selector": "$steps.tracker.tracked_detections" },
      { "type": "JsonField", "name": "count_in", "selector": "$steps.line.count_in" },
      { "type": "JsonField", "name": "count_out", "selector": "$steps.line.count_out" }
    ]
  }
}
